# Admin (copy to .env.local; never commit secrets)
ADMIN_PASSWORD=
# HMAC signing key for admin session cookie — use 32+ random bytes in production (openssl rand -hex 32)
ADMIN_SESSION_SECRET=

# Cron & worker — 로컬·Vercel 동일하게 필수 (크론·process-draft·Worker 무단 호출 방지)
# CRON_SECRET=
# Worker 전용(선택). 없으면 CRON_SECRET으로 Worker Bearer 검증
# WORKER_SECRET=

# Optional: distributed rate limit for /api/admin/login (recommended in production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
